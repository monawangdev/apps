---
import GlobalNav from '../components/GlobalNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { localeMeta, localePath, type Locale } from '../content/i18n';

export type AlternateLink = {
  locale: Locale;
  href: string;
};

type Props = {
  locale: Locale;
  title: string;
  description: string;
  path: string;
  alternates: AlternateLink[];
  jsonLd?: unknown[];
};

const { locale, title, description, path, alternates, jsonLd = [] } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (href: string) => `${base}${href.replace(/^\/+/, '')}`;
const canonical = new URL(withBase(path), Astro.site).toString();
---

<!doctype html>
<html lang={localeMeta[locale].lang} dir={localeMeta[locale].dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={localeMeta[alternate.locale].lang} href={new URL(withBase(alternate.href), Astro.site).toString()} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(withBase(localePath('en', path.replace(/^\/[^/]+\/?/, ''))), Astro.site).toString()} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <link rel="stylesheet" href={withBase('/assets/styles.css')} />
    <meta name="theme-color" content="#000000" />
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('safari-format-theme');
        if (saved === 'light' || saved === 'dark') document.documentElement.dataset.theme = saved;
      })();
    </script>
    {jsonLd.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <GlobalNav locale={locale} alternates={alternates} />
    <slot />
    <SiteFooter locale={locale} />
    <script src={withBase('/assets/site.js')} defer></script>
  </body>
</html>
