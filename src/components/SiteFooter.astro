---
import { localePath, type Locale, ui } from '../content/i18n';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = ui[locale];
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (href: string) => `${base}${href.replace(/^\/+/, '')}`;
---

<footer class="site-footer">
  <div>
    <strong>{t.family}</strong>
    <p>{t.footerLead}</p>
  </div>
  <nav aria-label="Footer">
    <a href={withBase(localePath(locale))}>{t.navApps}</a>
    <a href={withBase(localePath(locale, 'privacy/'))}>{t.navPrivacy}</a>
    <a href={withBase(localePath(locale, 'contact/'))}>{t.navContact}</a>
  </nav>
</footer>
