---
import type { ProductApp } from '../content/apps';
import type { Locale } from '../content/i18n';
import { localePath, ui } from '../content/i18n';

type Props = {
  app: ProductApp;
  locale: Locale;
  index: number;
};

const { app, locale, index } = Astro.props;
const copy = app.copy[locale];
const t = ui[locale];
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (href: string) => `${base}${href.replace(/^\/+/, '')}`;
const toneClass = index % 2 === 1 ? 'catalog-card catalog-card-alt' : 'catalog-card';
---

<article class={toneClass} style={`--accent:${app.accent}`}>
  <div class="tile-copy">
    <img class="app-icon" src={withBase(`/assets/icons/${app.icon}`)} alt="" width="72" height="72" loading="lazy" />
    <p class="eyebrow">{app.category}</p>
    <h2>{copy.tagline}</h2>
    <p>{copy.description}</p>
    <ul class="core-feature-list">
      {copy.features.slice(0, 3).map((feature) => <li>{feature}</li>)}
    </ul>
    <div class="platform-row" aria-label="Platforms">
      {app.platforms.map((platform) => <span>{platform}</span>)}
    </div>
    <a class="text-link" href={withBase(localePath(locale, `apps/${app.id}/`))}>{t.learnMore}</a>
  </div>
</article>
